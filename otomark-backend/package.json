{
    "name": "otomark-backend",
    "version": "1.0.0",
    "description": "Otomark - 音楽レビューSNS バックエンドAPI",
    "type": "module",
    "scripts": {
        "dev": "npx tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "node --import tsx/esm src/db/migrate.ts",
        "db:seed": "node --import tsx/esm src/db/seed.ts"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.11",
        "@hono/zod-validator": "^0.7.6",
        "bcryptjs": "^2.4.3",
        "dotenv": "^16.6.1",
        "hono": "^4.12.8",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.20.0",
        "stripe": "^20.4.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.6",
        "tsx": "^4.16.0",
        "typescript": "^5.5.0"
    }
}
