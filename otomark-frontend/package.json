{
    "name": "otomark-frontend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev --port 3001",
        "dev:prod": "next start --port 3001",
        "dev:clean": "sh -c 'lsof -tiTCP:3001 -sTCP:LISTEN 2>/dev/null | xargs kill -9 2>/dev/null; rm -rf .next node_modules/.cache && next dev --port 3001'",
        "dev:reset": "rm -rf .next node_modules/.cache",
        "build": "next build",
        "start": "next start",
        "lint": "next lint"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@tanstack/react-query": "^5.51.0",
        "@tanstack/react-query-devtools": "^5.51.0",
        "axios": "^1.7.2",
        "clsx": "^2.1.1",
        "next": "^14.2.35",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "zustand": "^4.5.4"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@types/spotify-web-playback-sdk": "^0.1.19",
        "typescript": "^5.5.0"
    }
}
